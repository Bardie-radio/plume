<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Plume</title>
    <link rel="stylesheet" href="~/dist/assets/main.css" asp-append-version="true" />
</head>
<body>
    <header>
        <p>Plume</p>
    </header>
    <main>
        @RenderBody()
    </main>
    <script type="module" src="~/dist/assets/main.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
