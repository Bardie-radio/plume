<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>aspnet-Plume-a4730ed9-8a6e-44b4-8c6f-b8cbdb55c498</UserSecretsId>
    <DefaultItemExcludes>$(DefaultItemExcludes);tests\**</DefaultItemExcludes>
  </PropertyGroup>

  <!-- Optional: build frontend assets on `dotnet publish` when Node is available. -->
  <Target Name="NpmBuild" BeforeTargets="Publish" Condition="Exists('package.json')">
    <Exec Command="npm ci" Condition="Exists('package-lock.json')" />
    <Exec Command="npm install" Condition="!Exists('package-lock.json')" />
    <Exec Command="npm run build" />
  </Target>

</Project>
